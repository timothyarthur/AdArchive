<?xml version="1.0" encoding="UTF-8"?>
<heresies_issue xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
 xsi:noNamespaceSchemaLocation="heresies_issue.xsd" uri="sample:HERESIES_ISSUE_URI">
    <issue_no>HERESIES ISSUE NO</issue_no>
    <title>HERESIES ISSUE TITLE</title>
    <pub_year>HERESIES ISSUE YEAR</pub_year>
    <pub_month>HERESIES ISSUE MONTH</pub_month>
    <ad>
        <!--for all ads-->
        <!--ad_label>Heresies Issue [Issue no] [Main Subject] Ad</ad_label-->
        <clipping_uri>sample:AD_CLIPPING</clipping_uri>
        <ad_creators uri="sample:AD_CREATORS_URI">
            <name>AD CREATORS NAME</name>
            <location>
                <address>AD CREATORS ADDRESS</address>
                <coordinates>AD CREATORS COORDINATES</coordinates>
                <phone_number>AD CREATORS PHONE NUMBER</phone_number>
            </location>
        </ad_creators>
        
        <!--for subject information not included elsewhere-->
        <about>sample:AD_ABOUT</about>
        
        <!--for ads of publications-->
        <publication_advertised uri="sample:PUBLICATION_URI">
            <!-- Title types: bibo:shortTitle, wikidata:Q1135389 (subtitle) -->
            <title>PUBLICATION TITLE</title>
            <creator>
                <name>PUB CREATOR NAME</name>
                <role>sample:PUB_CREATOR_ROLE</role>
            </creator>
            <type>sample:PUB_TYPE</type>
            <about>sample:PUB_ABOUT</about>
            <no_pages>NUMBER OF PAGES</no_pages>
            
            <!--For serial publications-->
            <issuing_rule>
                <no_issues>NUMBER OF ISSUES</no_issues>
                <time_span>TIME SPAN</time_span>
            </issuing_rule>
            <issue_advertised uri="sample:ISSUE_URI">
                <title>ISSUE TITLE<number>ISSUE NUMBER</number>
                    <date>ISSUE DATE<type>ISSUE DATE TYPE</type>
                    </date>
                </title>
                <!--For articles specified as part of the given issue-->
                <article_advertised>
                    <title>ARTICLE TITLE</title>
                    <creators>
                        <creator>sample:ARTICLE_CREATOR</creator>
                        <role>sample:ARTICLE_CREATOR_ROLE</role>
                    </creators>
                    <about>sample:ARTICLE_ABOUT</about>
                </article_advertised>
            </issue_advertised>
            
            <!-- For articles not tied to a specific issue-->
            <article_advertised>
                <title>ARTICLE TITLE</title>
                <creators>
                    <creator>sample:ARTICLE_CREATOR</creator>
                    <role>sample:ARTICLE_CREATOR_ROLE</role>
                </creators>
                <about>sample:ARTICLE_ABOUT</about>
            </article_advertised>
            
        </publication_advertised>
        
        <!--Features and topics-->
        <features_list>
            <text>FEATURES LIST TEXT</text>
            <feature>sample:FEATURE</feature>
            <subject>sample:FEATURE_LIST_SUBJECT</subject>
        </features_list>
        
        <topics_list>
            <text>TOPIC LIST TEXT</text>
            <topic>sample:TOPIC</topic>
            <subject>sample:TOPIC_LIST_SUBJECT</subject>
        </topics_list>
        
        <!--ad copy-->
        <copy>
            <about>sample:COPY_ABOUT</about>
            <text>COPY TEXT</text>
            <author>COPY AUTHOR</author>
            <date>COPY DATE</date>
            <source>COPY SOURCE</source>
            <!--types: endorsement-->
            <type>COPY TYPE</type>
        </copy>
        
        <!--for ads with prices-->
        <ad_price>
            <price_subject>sample:PRICE_SUBJECT</price_subject>
            <price_value>PRICE VALUE</price_value>
            <price_currency>PRICE CURRENCY</price_currency>
            <type>sample:PRICE_TYPE</type>
        </ad_price>
        
        <!--For ads with illustrations-->
        <illustration>
            <about>ILLUSTRATION ABOUT</about>
            <represents>sample:ILLUSTRATION_REPRESENTS</represents>
            <clipping>sample:ILLUSTRATION_CLIPPING</clipping>
        </illustration>
        
        <!--For ads with embedded ads (usually ads for several monographs)-->
        <embedded_ad>
            <publication_advertised uri="sample:EMBEDDED_PUBLICATION_URI">
                <!-- Title types: bibo:shortTitle, wikidata:Q1135389 (subtitle) -->                
                <title>PUBLICATION TITLE 
                    <type>sample:PUB_TITLE_TYPE</type>
                </title>
                <type>sample:PUB_TYPE</type>
                <about>sample:PUB_ABOUT</about>
                <no_pages>NUMBER OF PAGES</no_pages>
                <creators>
                    <creator>sample:PUB_CREATOR</creator>
                    <!-- Example roles: wikidata:Q482980 (author), wikidata:Q1607826 (editor), 
                    wikidata:Q2516866 (publisher) -->
                    <role>sample:PUB_CREATOR_ROLE</role>
                </creators>
            </publication_advertised>
            
            <copy>
                <about>sample:COPY_ABOUT</about>
                <text>COPY TEXT</text>
                <author>COPY AUTHOR</author>
                <date>COPY DATE</date>
                <source>COPY SOURCE</source>
                <!--types: endorsement-->
                <type>COPY TYPE</type>
            </copy>
            
            <ad_price>
                <price_subject>sample:PRICE_SUBJECT</price_subject>
                <price_value>PRICE VALUE</price_value>
                <price_currency>PRICE CURRENCY</price_currency>
                <type>sample:PRICE_TYPE</type>
            </ad_price>
            
        </embedded_ad>
    </ad>
</heresies_issue>
