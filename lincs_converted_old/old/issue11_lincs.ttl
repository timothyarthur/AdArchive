# SECTION 2.8 - AD8

# This is the advertisement
<MANIFESTATION_HERESIES_I11_AD8> a frbroo:F3_Manifestation ; 
  rdfs:label "Heresies 11 Calyx advertisement" ;
  # has a Type of "advertisement"
  crm:P2_has_type wikidata:Q39911916 ;
  # is published in I11 - here using property of P148, is there need to further specify?
  # not really clear on distinction between frbroo:R5 and crm:P148
  crm:P148i_is_component_of worldcat:7460627 ;
  # advertisement is about things: journal, specific issue, price (4), address
  crm:P129_is_about wikidata:Q5024773,
  	<CALYX_INTERNATIONAL>,
  	<AD_PRICE_I11_AD8_P1>,
	<AD_PRICE_I11_AD8_P2>,
	<AD_PRICE_I11_AD8_P3>,
	<AD_PRICE_I11_AD8_P4>,
  	<CALYX_CREATOR_ADDRESS> ;
  # created by the organization running the ad
  frbroo:R24i_was_created_through [ a frbroo:F30_Manifestation_Creation ; 
    crm:P14_carried_out_by <CALYX_CREATOR> ] ; 
  # text copy in the advertisement
  crm:P165_incorporates <CALYX_AD_COPY_1>, 
  	<CALYX_FEATURES_LIST_1> ;
  # has a visual representation that can be located at the following iiif address
  crm:P138i_has_representation <https://iiif.archivelab.org/iiif/heresies_11$95/1538,161,905,1291/full/0/default.jpg> ; 
        rdfs:label "Heresies 11 Calyx advertisement - visual representation" .



