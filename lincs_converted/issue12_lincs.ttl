# These are the things being incorporated

<FUSE_AD_COPY_1> a crm:E33_Linguistic_Object ;
  crm:P129_is_about wikidata:Q5509975 ;
  crm:P2_has_type "advertising copy" ;
  crm:P190_has_content "FUSE focuses on socially relevant contemporary culture which ensures comprehensive women's coverage, such as Women's Performance, the Economic Position of Women within the Arts, the UN Festival of Women Artists, 'Pornographic' Women's Art, and the Multi-media Incest Awareness Project from the Women's Building in Los Angeles. Profiles of contemporary feminist artists like Carolee Schneeman, Martha Rosler, and Susan Britton appear regularly ... and then of course there are reviews of books, films, videotapes, exhibitions, records, performances - alternative works by and for women." .

<FUSE_AD_COPY_2> a crm:E33_Linguistic_Object ;
  crm:P129_is_about wikidata:Q5509975 ;
  crm:P2_has_type "advertising copy" ;
  crm:P190_has_content "Outside of the cultural field, features on Women & Infanticide, the Criminalization of Immigrant Women, Makeup as Mask, Anorexia Nervosa, Unionized Women vs. Surveillance Systems, Censorship & Women, Strippers Unionizing, and Media Access for Women have appeared in the past two years." .

<FUSE_TOPIC_LIST_1> a crm:E33_Linguistic_Object ;
  crm:P129_is_about wikidata:Q5509975 ;
  crm:P2_has_type "advertising copy" ;
