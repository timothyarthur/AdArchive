<file:///Users/tim/Documents/AdArchive/WOMANSPIRIT_AD_COPY_2> a crmpc:E33_Linguistic_Object ;
    crmpc:P129_is_about wikidata:Q48732990,
        "diary entries",
        "drawings",
        "letters",
        "love between women over sixty",
        "photos",
        "poems",
        "short prose pieces",
        "songs" ;
    crmpc:P190_has_symbolic_content "For an anthology, we are collecting accounts of love between women over sixty, for their unique perspective on our loving lives. We are interested in reading your material. Send your poems, short prose pieces, letters, diary entries, songs, photos and drawings. Photocopies, please. Include S.A.S.E. Deadline extended to Crones Day—Halloween 1988. Send material to OLD LOVERS, c/o WomanSpirit, 2000 King Mountain Trail, Sunny Valley, OR 97497." ;
    crmpc:P2_has_type "ad copy" .

